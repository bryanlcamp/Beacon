{
  "application": {
    "name": "Beacon Client Algorithm",
    "version": "1.0.0",
    "description": "High-frequency trading algorithm with market data reception and order execution",
    "architecture": "playback (UDP) -> client_algorithm <--> (TCP) matching_engine"
  },
  "network": {
    "market_data": {
      "protocol": "udp",
      "host": "127.0.0.1",
      "port": 12345,
      "multicast_address": "239.255.0.1",
      "timeout_ms": 1000
    },
    "exchange": {
      "protocol": "tcp",
      "host": "127.0.0.1",
      "port": 54321,
      "timeout_ms": 5000,
      "keepalive": true
    }
  },
  "trading": {
    "order_frequency": 10,
    "default_time_in_force": "0",
    "default_capacity": "A",
    "max_order_rate": 1000
  },
  "risk_management": {
    "pnl_drawdown_warning": -5000.0,
    "pnl_drawdown_alert": -10000.0,
    "pnl_drawdown_hard_stop": -15000.0,
    "order_reject_warning": 10,
    "order_reject_alert": 25,
    "order_reject_hard_stop": 50,
    "order_messaging_burst_warning": 100,
    "order_messaging_burst_alert": 250,
    "order_messaging_burst_hard_stop": 500
  },
  "products": [
    {
      "symbol": "AAPL",
      "starting_position": 0,
      "algo_position_limit": 10000,
      "firm_position_limit": 10000,
      "enabled": true
    },
    {
      "symbol": "MSFT",
      "starting_position": 500,
      "algo_position_limit": 5000,
      "firm_position_limit": 5000,
      "enabled": true
    },
    {
      "symbol": "GOOGL",
      "starting_position": -200,
      "algo_position_limit": 2000,
      "firm_position_limit": 2000,
      "enabled": true
    },
    {
      "symbol": "TSLA",
      "starting_position": 1000,
      "algo_position_limit": 8000,
      "firm_position_limit": 8000,
      "enabled": true
    }
  ]
}