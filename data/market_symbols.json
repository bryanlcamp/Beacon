/**
 * Market Data Loader for Beacon Dataset Generator
 * Loads symbol data from external JSON file for easy maintenance
 */

let MARKET_DATA = {};
let MARKET_CATEGORIES = {};
let MARKET_METADATA = {};

// Load market data from JSON file
async function loadMarketData() {
    try {
        const response = await fetch('./market_symbols.json');
        const data = await response.json();
        
        MARKET_DATA = data.symbols;
        MARKET_CATEGORIES = data.categories;
        MARKET_METADATA = data.metadata;
        
        console.log(`📊 Loaded ${MARKET_METADATA.totalSymbols} market symbols (v${MARKET_METADATA.version})`);
        return true;
    } catch (error) {
        console.error('❌ Failed to load market data:', error);
        // Fallback to embedded basic data
        loadFallbackData();
        return false;
    }
}

// Fallback data if JSON fails to load
function loadFallbackData() {
    console.log('📦 Using fallback market data');
    MARKET_DATA = {
        // ...existing code... (keep a few essential symbols as fallback)
        'AAPL': {
            name: 'Apple Inc.',
            sector: 'Technology',
            prevDay: { open: 191.50, high: 195.20, low: 190.75, close: 193.45, volume: 52000000 },
            priceRange: { min: 185.00, max: 200.00 },
            quantityRange: { min: 100, max: 2000 },
            spreadPercent: 0.02,
            tradeProbability: 0.30,
            category: "mega-cap-tech"
        },
        'SPY': {
            name: 'SPDR S&P 500 ETF',
            sector: 'ETF',
            prevDay: { open: 458.90, high: 462.15, low: 457.75, close: 460.85, volume: 60000000 },
            priceRange: { min: 450.00, max: 470.00 },
            quantityRange: { min: 100, max: 3000 },
            spreadPercent: 0.01,
            tradeProbability: 0.25,
            category: "major-etf"
        }
    };
}

// Enhanced utility functions
const MarketDataUtils = {
    /**
     * Initialize market data (call this first)
     */
    init: async function() {
        return await loadMarketData();
    },

    /**
     * Get symbol data by ticker
     */
    getSymbol: function(ticker) {
        return MARKET_DATA[ticker.toUpperCase()];
    },
    
    /**
     * Get all available symbols
     */
    getAllSymbols: function() {
        return Object.keys(MARKET_DATA);
    },
    
    /**
     * Get symbols by sector
     */
    getSymbolsBySector: function(sector) {
        return Object.entries(MARKET_DATA).filter(([ticker, data]) => 
            data.sector === sector
        );
    },

    /**
     * Get symbols by category
     */
    getSymbolsByCategory: function(category) {
        return Object.entries(MARKET_DATA).filter(([ticker, data]) => 
            data.category === category
        );
    },
    
    /**
     * Get sector summary with counts
     */
    getSectorSummary: function() {
        const sectors = {};
        Object.values(MARKET_DATA).forEach(data => {
            sectors[data.sector] = (sectors[data.sector] || 0) + 1;
        });
        return sectors;
    },

    /**
     * Get category summary with counts
     */
    getCategorySummary: function() {
        const categories = {};
        Object.values(MARKET_DATA).forEach(data => {
            categories[data.category] = (categories[data.category] || 0) + 1;
        });
        return categories;
    },
    
    /**
     * Search symbols by name or ticker
     */
    searchSymbols: function(query) {
        const searchTerm = query.toLowerCase();
        return Object.entries(MARKET_DATA).filter(([ticker, data]) => 
            ticker.toLowerCase().includes(searchTerm) || 
            data.name.toLowerCase().includes(searchTerm)
        );
    },
    
    /**
     * Get symbols by liquidity (volume-based categories)
     */
    getSymbolsByLiquidity: function(category) {
        const categories = {
            'ultra-high': symbols => symbols.filter(([, data]) => data.prevDay.volume >= 40000000),
            'high': symbols => symbols.filter(([, data]) => data.prevDay.volume >= 15000000 && data.prevDay.volume < 40000000),
            'medium': symbols => symbols.filter(([, data]) => data.prevDay.volume >= 5000000 && data.prevDay.volume < 15000000),
            'standard': symbols => symbols.filter(([, data]) => data.prevDay.volume < 5000000)
        };
        
        const allSymbols = Object.entries(MARKET_DATA);
        return categories[category] ? categories[category](allSymbols) : allSymbols;
    },
    
    /**
     * Get recommended symbols for HFT (high volume, tight spreads)
     */
    getHFTRecommended: function() {
        return Object.entries(MARKET_DATA).filter(([, data]) => 
            data.prevDay.volume >= 15000000 && data.spreadPercent <= 0.03
        );
    },

    /**
     * Get metadata about the dataset
     */
    getMetadata: function() {
        return MARKET_METADATA;
    },

    /**
     * Get category descriptions
     */
    getCategories: function() {
        return MARKET_CATEGORIES;
    }
};

// Export for both Node.js and browser environments
if (typeof module !== 'undefined' && module.exports) {
    module.exports = { MarketDataUtils, loadMarketData };
} else if (typeof window !== 'undefined') {
    window.MarketDataUtils = MarketDataUtils;
    window.loadMarketData = loadMarketData;
}