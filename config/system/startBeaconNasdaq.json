{
  "system_config": {
    "name": "NASDAQ ITCH VWAP Strategy",
    "protocol": "itch",
    "algorithm": "vwap",
    "duration_seconds": 600,
    "description": "NASDAQ equity trading with VWAP execution algorithm"
  },
  "generator": {
    "enabled": true,
    "output_file": "temp_data/nasdaq_market_data.bin",
    "message_count": 25000,
    "symbols": ["AAPL", "MSFT", "GOOGL", "AMZN", "TSLA"],
    "protocol": "itch_50",
    "wave_config": {
      "price_volatility": 0.015,
      "volume_burst_probability": 0.15,
      "trend_duration_seconds": 90
    }
  },
  "playback": {
    "enabled": true,
    "networking": {
      "host": "127.0.0.1",
      "port": 8002,
      "protocol": "UDP"
    },
    "playback_config": {
      "input_file": "temp_data/nasdaq_market_data.bin",
      "rate_limit_mbps": 200,
      "burst_mode": true,
      "protocol": "itch_50"
    }
  },
  "matching_engine": {
    "enabled": true,
    "networking": {
      "host": "127.0.0.1",
      "port": 9002,
      "protocol": "TCP"
    },
    "protocol": {
      "order_entry": "ouch_50",
      "auto_detect": false,
      "strict_validation": true
    },
    "execution": {
      "immediate_fill": true,
      "partial_fills": true,
      "price_improvement": 0.01
    }
  },
  "client_algorithm": {
    "enabled": true,
    "type": "vwap",
    "networking": {
      "market_data": {
        "host": "127.0.0.1",
        "port": 8002,
        "protocol": "UDP"
      },
      "order_entry": {
        "host": "127.0.0.1",
        "port": 9002,
        "protocol": "TCP"
      }
    },
    "protocol_config": {
      "market_data_protocol": "itch_50",
      "order_entry_protocol": "ouch_50"
    },
    "execution_config": {
      "symbol": "AAPL",
      "side": "B",
      "shares": 5000,
      "limit_price": 150.25
    },
    "vwap_algorithm": {
      "lookback_window_minutes": 20,
      "participation_rate": 0.25,
      "volume_curve": "historical_intraday",
      "aggressive_threshold": 0.8,
      "minimum_order_size": 100
    }
  },
  "system_monitoring": {
    "log_level": "DEBUG",
    "performance_metrics": true,
    "real_time_display": true,
    "output_directory": "logs/nasdaq_session_$(timestamp)"
  }
}